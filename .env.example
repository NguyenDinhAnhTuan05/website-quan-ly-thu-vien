# ============================================================
# JWT Configuration
# PHẢI thay bằng key >= 256-bit (64 hex chars)
# Generate: openssl rand -hex 32
# ============================================================
JWT_SECRET=CHANGE_ME_chay_openssl_rand_hex_32_de_lay_key
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000


# Gemini AI API Key
GEMINI_API_KEY=CHANGE_ME_lay_tai_aistudio_google_com

# Email (Gmail App Password)
MAIL_USERNAME=CHANGE_ME_your_gmail@gmail.com
MAIL_PASSWORD=CHANGE_ME_gmail_app_password_16_chars

# Google OAuth2
GOOGLE_CLIENT_ID=CHANGE_ME_google_client_id
GOOGLE_CLIENT_SECRET=CHANGE_ME_google_client_secret


# ============================================================
# Application Settings
# ============================================================
SPRING_PROFILE=production
APP_PORT=8080

# ============================================================
# MySQL Configuration
# ============================================================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=library_db
MYSQL_USER=library_user
MYSQL_PASSWORD=library_pass
MYSQL_PORT=3307

# ============================================================
# Redis Configuration
# ============================================================
REDIS_PASSWORD=redis_secure_pass
REDIS_PORT=6379

# ============================================================
# Database Credentials (Backend)
# ============================================================
DB_USERNAME=library_user
DB_PASSWORD=library_pass

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://36.50.135.61:8080

# ============================================================
# Database SSL (Production: true)
# ============================================================
DB_USE_SSL=false
DB_ALLOW_PUBLIC_KEY=true

# ============================================================
# Logging
# ============================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_NHOM10=INFO

# ============================================================
# Payment Gateway — Return URLs trỏ về server
# ============================================================
VNPAY_RETURN_URL=http://36.50.135.61:8080/api/payment/vnpay-return
MOMO_RETURN_URL=http://36.50.135.61:8080/api/payment/momo-return
MOMO_NOTIFY_URL=http://36.50.135.61:8080/api/payment/momo-notify

# ============================================================
# GitHub OAuth2 (tùy chọn — để dummy nếu không dùng)
# ============================================================
GITHUB_CLIENT_ID=dummy
GITHUB_CLIENT_SECRET=dummy