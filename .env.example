# ============================================================
# Environment Configuration Example
# Copy to .env and fill in your values
# ============================================================

# ============================================================
# Application Settings
# ============================================================
SPRING_PROFILE=production
APP_PORT=8080

# ============================================================
# MySQL Configuration
# ============================================================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=library_db
MYSQL_USER=library_user
MYSQL_PASSWORD=library_pass
MYSQL_PORT=3306

# ============================================================
# Redis Configuration
# ============================================================
REDIS_PASSWORD=redis_secure_pass
REDIS_PORT=6379

# ============================================================
# Database Credentials (Backend)
# ============================================================
DB_USERNAME=library_user
DB_PASSWORD=library_pass

# ============================================================
# JWT Configuration
# PHẢI thay bằng key >= 256-bit (64 hex chars)
# Generate: openssl rand -hex 32
# ============================================================
JWT_SECRET=THAY_BANG_KEY_THAT_CUA_BAN
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ============================================================
# Email (Gmail App Password — không dùng mật khẩu thật)
# ============================================================
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ============================================================
# OAuth2 — Google & GitHub
# ============================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================================
# Gemini AI — Google Generative AI
# Lấy API key tại: https://aistudio.google.com/app/apikey
# ============================================================
GEMINI_API_KEY=your-gemini-api-key

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# Database SSL (Production: true)
# ============================================================
DB_USE_SSL=false
DB_ALLOW_PUBLIC_KEY=true

# ============================================================
# Logging
# ============================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_NHOM10=INFO
